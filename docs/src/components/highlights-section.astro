---
import FeatureRow from './feature-row.astro';
import HowStep from './how-step.astro';
import ShieldCheck from '../icons/shield-check.astro';
import Bolt from '../icons/bolt.astro';
import Globe from '../icons/globe.astro';
import FileText from '../icons/file-text.astro';
import Activity from '../icons/activity.astro';
import TerminalPrompt from '../icons/terminal-prompt.astro';
import Route from '../icons/route.astro';
import Folder from '../icons/folder.astro';
---

<section class="py-11" id="highlights">
  <div class="max-w-[var(--max-width)] mx-auto px-[var(--padding-x)]">
    <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-primary mb-3">Highlights</p>
    <h2 class="font-heading text-[22px] font-semibold tracking-[-0.02em] mb-1.5 text-text max-sm:text-xl">Features</h2>
    <p class="text-text-tertiary text-sm mb-5 leading-[1.5]">
      Everything you need for local development, built into a single binary.
    </p>
    <div class="grid grid-cols-2 gap-3 max-sm:grid-cols-1">
      <FeatureRow title="Automatic HTTPS" description="Trusted certificates, green lock, no warnings.">
        <ShieldCheck />
      </FeatureRow>
      <FeatureRow title="WebSocket & HMR" description="Next.js, Vite, and others work out of the box.">
        <Bolt />
      </FeatureRow>
      <FeatureRow title="Multiple Domains" description="Each gets its own certificate and proxy.">
        <Globe />
      </FeatureRow>
      <FeatureRow title="Access Logging" description="Full, minimal, or off. Tail and filter by domain.">
        <FileText />
      </FeatureRow>
      <FeatureRow title="Health Monitoring" description="See which upstreams are reachable at a glance.">
        <Activity />
      </FeatureRow>
      <FeatureRow title="Path Routing" description="Route different URL paths to different upstream ports.">
        <Route />
      </FeatureRow>
      <FeatureRow title="Project Config" description="Share your dev setup with teammates via .slim.yaml.">
        <Folder />
      </FeatureRow>
      <FeatureRow title="Zero Config" description="First run handles CA, trust, and port forwarding.">
        <TerminalPrompt />
      </FeatureRow>
    </div>
  </div>
</section>

<section class="py-11">
  <div class="max-w-[var(--max-width)] mx-auto px-[var(--padding-x)]">
    <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-primary mb-3">Under the Hood</p>
    <h2 class="font-heading text-[22px] font-semibold tracking-[-0.02em] mb-1.5 text-text max-sm:text-xl">How it works</h2>
    <p class="text-text-tertiary text-sm mb-4 leading-[1.5]">
      A single Go binary that handles everything under the hood.
    </p>
    <div class="flex flex-col">
      <HowStep number="1">
        <strong class="text-[13.5px] font-semibold text-text">Generates a root CA</strong>
        <span class="text-[13.5px] text-text-tertiary ml-0.5 max-sm:block max-sm:ml-0 max-sm:mt-0.5">and trusts it in macOS Keychain or Linux CA store.</span>
      </HowStep>
      <HowStep number="2">
        <strong class="text-[13.5px] font-semibold text-text">Creates per-domain certificates</strong>
        <span class="text-[13.5px] text-text-tertiary ml-0.5 max-sm:block max-sm:ml-0 max-sm:mt-0.5">on demand, served via SNI for each <code class="bg-[#f5f5f5] px-[5px] py-px rounded-[3px] text-xs">.local</code> domain.</span>
      </HowStep>
      <HowStep number="3">
        <strong class="text-[13.5px] font-semibold text-text">Manages <code class="bg-[#f5f5f5] px-[5px] py-px rounded-[3px] text-xs font-medium">/etc/hosts</code></strong>
        <span class="text-[13.5px] text-text-tertiary ml-0.5 max-sm:block max-sm:ml-0 max-sm:mt-0.5">entries automatically, pointing domains to <code class="bg-[#f5f5f5] px-[5px] py-px rounded-[3px] text-xs">127.0.0.1</code>.</span>
      </HowStep>
      <HowStep number="4">
        <strong class="text-[13.5px] font-semibold text-text">Forwards ports 80/443</strong>
        <span class="text-[13.5px] text-text-tertiary ml-0.5 max-sm:block max-sm:ml-0 max-sm:mt-0.5">via <code class="bg-[#f5f5f5] px-[5px] py-px rounded-[3px] text-xs">pfctl</code> or <code class="bg-[#f5f5f5] px-[5px] py-px rounded-[3px] text-xs">iptables</code> so the proxy runs unprivileged.</span>
      </HowStep>
      <HowStep number="5">
        <strong class="text-[13.5px] font-semibold text-text">Reverse proxies requests</strong>
        <span class="text-[13.5px] text-text-tertiary ml-0.5 max-sm:block max-sm:ml-0 max-sm:mt-0.5">with HTTP/2, WebSocket upgrades, and CORS headers.</span>
      </HowStep>
    </div>
  </div>
</section>
