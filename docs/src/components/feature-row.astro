---
const props = Astro.props;
const { title, description } = props;
---

<div class="flex items-start gap-3 rounded-xl border border-border p-3.5 transition-colors hover:bg-[#fafafa]">
  <div class="shrink-0 size-8 rounded-lg bg-[#f5f5f5] flex items-center justify-center">
    <slot />
  </div>
  <div class="min-w-0">
    <strong class="text-[13.5px] font-semibold text-text">{title}</strong>
    <p class="text-[13px] text-text-tertiary mt-0.5 leading-[1.45]">{description}</p>
  </div>
</div>
